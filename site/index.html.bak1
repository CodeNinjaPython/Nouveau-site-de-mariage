<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Jérémie & Jeannette | Prestations photo et vidéo de mariage</title>
  <meta name="description" content="Prestations photo et vidéo de mariage en Île-de-France: formules élégantes, approche éditoriale et films poétiques pour raconter votre journée.">
  <link rel="stylesheet" href="css/styles.css">
</head>
<body>
  <a class="skip-link" href="#accueil">Aller au contenu</a>

  <header class="topbar" role="banner">
    <a class="brand" href="#accueil">Jérémie & Jeannette</a>
    <nav aria-label="Navigation principale">
      <a href="#accueil">Accueil</a>
      <a href="#prestations">Prestations</a>
      <a href="#gamme">Tarifs</a>
      <a href="#docu">Docu Portrait</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <main id="accueil">
    <section class="hero">
      <div class="hero-copy reveal">
        <p class="eyebrow">Photo & vidéo de mariage</p>
        <h1 class="accroche gold-text">votre histoire</h1>
        <p class="sub">
          Une présence douce, des images vraies, une direction artistique sensible.
          Nous créons des souvenirs à la fois spontanés et cinématographiques,
          du premier regard jusqu'aux dernières danses.
        </p>
        <div class="hero-actions">
          <button id="heroInvite" class="invite" type="button">Découvrir les univers</button>
          <a class="text-link" href="#gamme">Voir les tarifs</a>
          <a class="mail" href="mailto:contact@jeremie-jeannette.fr">contact@jeremie-jeannette.fr</a>
        </div>
      </div>

      <div class="hero-visual reveal" aria-hidden="true">
        <img class="hero-sheet hero-sheet-main" src="assets/img/packs/photo-video.png" alt="">
        <img class="hero-sheet hero-sheet-back" src="assets/img/packs/photo.png" alt="">
        <div class="hero-stats">
          <span><b>120+</b> mariages</span>
          <span><b>8 ans</b> d'expérience</span>
          <span><b>72h</b> option express</span>
        </div>
      </div>
    </section>

    <section id="prestations" class="choice" aria-label="Choisir votre univers">
      <header class="page-head reveal">
        <span class="script gold-text">prestations</span>
        <p class="mariage">Choisissez l'univers qui vous ressemble</p>
      </header>

      <div class="choice-grid">
        <article class="choice-card" data-univers="photo" tabindex="0" aria-label="Univers photo">
          <div class="media">
            <img class="illu" src="assets/img/illustrations/Bouquet.png" alt="Illustration photo">
          </div>
          <h3 class="gold-text">Photos</h3>
          <p class="tag">Lumière naturelle & émotions</p>
          <p class="from">À partir de <b>300€</b></p>
        </article>

        <article class="choice-card" data-univers="video" tabindex="0" aria-label="Univers vidéo">
          <div class="media">
            <img class="illu" src="assets/img/illustrations/video/Cupidon.png" alt="Illustration vidéo">
          </div>
          <h3 class="gold-text">Vidéos</h3>
          <p class="tag">Film poétique & narration</p>
          <p class="from">À partir de <b>300€</b></p>
        </article>

        <article class="choice-card" data-univers="mix" tabindex="0" aria-label="Univers photo et vidéo">
          <div class="media">
            <img class="illu" src="assets/img/illustrations/Bague.png" alt="Illustration photo et vidéo">
          </div>
          <h3 class="gold-text">Photos & Vidéos</h3>
          <p class="tag">Couverture complète de la journée</p>
          <p class="from">À partir de <b>500€</b></p>
        </article>
      </div>
    </section>

    <section id="gamme" class="gamme" hidden aria-label="Tarifs et options">
      <header class="page-head reveal">
        <span id="gammeScript" class="script gold-text">photos</span>
        <p class="mariage">Sélectionnez une formule puis comparez les options</p>
      </header>

      <div class="gamme-shell reveal">
        <div id="gammeSwitch" class="gamme-switch" role="tablist" aria-label="Univers de prestation">
          <button type="button" role="tab" data-univers="photo" aria-pressed="true" class="is-active">Photos</button>
          <button type="button" role="tab" data-univers="video" aria-pressed="false">Vidéos</button>
          <button type="button" role="tab" data-univers="mix" aria-pressed="false">Photos & Vidéos</button>
        </div>

        <div class="gamme-main">
          <div id="packsHost" class="packs" aria-live="polite"></div>
          <div id="optionsHost" class="gamme-options" aria-label="Options"></div>
        </div>
      </div>
    </section>

    <section id="docu" class="docu" aria-label="Docu portrait mariage">
      <header class="page-head reveal">
        <span class="script gold-text">docu portrait</span>
        <p class="mariage">Un récit intime de votre journée</p>
      </header>

      <p class="docu-intro reveal">
        Notre approche "Docu Portrait" suit le rythme réel de votre mariage,
        avec un regard <span class="hl">authentique, élégant et sensible</span>.
        Vous profitez pleinement de vos proches pendant que nous composons un
        reportage vivant: les détails, les larmes, les éclats de rire, et la fête.
      </p>

      <div class="docu-stamp reveal" aria-hidden="true">
        <span class="s1 gold-text">collection</span>
        <span class="s2">signature</span>
      </div>

      <div class="docu-grid reveal">
        <img class="docu-card" src="assets/img/packs/docu-portrait.png" alt="Aperçu du docu portrait mariage">
        <img class="docu-card" src="assets/img/packs/video.png" alt="Aperçu d'un film de mariage">
      </div>
    </section>
  </main>

  <footer id="contact" class="contact" aria-label="Contact">
    <img class="corner bl" src="assets/img/illustrations/Noeud.png" alt="">
    <img class="corner r" src="assets/img/illustrations/Champagne.png" alt="">

    <h2 class="gold-text reveal">contact</h2>
    <div class="contact-actions reveal">
      <a class="mail" href="mailto:contact@jeremie-jeannette.fr">Envoyer un email</a>
      <a class="tel" href="tel:+33600000000">+33 6 00 00 00 00</a>
    </div>
    <p class="zone reveal">Basés en Île-de-France · Déplacements dans toute la France</p>
    <p class="sign gold-text reveal">Jérémie & Jeannette</p>
  </footer>

  <script src="js/main.js" defer></script>
</body>
</html>
